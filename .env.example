# Dedup Study — AI model configuration.
# Copy this file to .env and fill in your values. The UI only picks WHICH of
# the four model options to run; endpoints, credentials, and model/engine ids
# all come from here. Real environment variables override this file.

# ---- Llama-3.1 via Ollama (OpenAI-compatible /v1 endpoint) -----------------
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama
OLLAMA_MODEL=llama3.1

# ---- Llama-4 via vLLM (OpenAI-compatible /v1 endpoint) ---------------------
VLLM_BASE_URL=http://ncslp30300:8814/v1
VLLM_API_KEY=EMPTY
VLLM_MODEL=meta-llama/Llama-4-Scout-17B-16E-Instruct

# ---- Claude Sonnet 4.6 / Haiku 4.5 via Elsa (FDA internal runPixel proxy) --
ELSA_BASE_URL=https://elsa-dev.preprod.fda.gov/Monolith/api/engine/runPixel
ELSA_API_NAME=
ELSA_API_KEY=
ELSA_SONNET_MODEL_ID=
ELSA_HAIKU_MODEL_ID=

# ---- Shared sampling parameters --------------------------------------------
DEDUP_AI_TEMPERATURE=0.1
DEDUP_AI_MAX_TOKENS=8000
